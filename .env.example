# =============================================================================
# Phalanx — example environment file
# =============================================================================
# Copy to .env and fill in real values. Docker Compose reads from .env.
# =============================================================================

# --- Core ---
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# --- API auth & CORS ---
# Comma-separated list of accepted bearer tokens. Empty disables auth (LOCAL DEV ONLY).
# Production deployments MUST set this; the dashboard, CLI, GitHub Action and CI tools
# all send Authorization: Bearer <token>.
PHALANX_API_TOKENS=
# Comma-separated origins for CORS (e.g. "http://localhost:3000,https://phalanx.example.com").
# Empty disables CORS entirely. "*" is allowed for explicit opt-in only.
PHALANX_CORS_ALLOWED_ORIGINS=

# --- Datastores ---
DATABASE_URL=postgresql://phalanx:phalanx@postgres:5432/phalanx
REDIS_URL=redis://redis:6379

# --- Queue (asynq) ---
PHALANX_QUEUE_CONCURRENCY=10
PHALANX_QUEUE_MAX_RETRIES=2
PHALANX_QUEUE_JOB_TIMEOUT=120000

# --- Audit ---
# Enable SHA-256 hash chaining for tamper-evident audit log
PHALANX_AUDIT_HASH_CHAIN=false
PHALANX_AUDIT_RETENTION_DAYS=1095

# --- Review behaviour ---
PHALANX_MAX_DIFF_SIZE=5000000
PHALANX_POST_COMMENT=true
PHALANX_CREATE_CHECK_RUN=true
PHALANX_BLOCK_MERGE_ON_FAIL=true

# --- GitHub integration ---
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com

# --- GitLab integration ---
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=
GITLAB_URL=https://gitlab.com

# --- Bitbucket Cloud integration ---
# BITBUCKET_AUTH is "<username>:<app_password>" or "x-token-auth:<workspace_token>".
# Setting it enables the Bitbucket platform client.
BITBUCKET_AUTH=
BITBUCKET_API_URL=https://api.bitbucket.org/2.0
# Bitbucket signs webhooks with the per-webhook UUID via X-Hook-UUID; set this
# to the same UUID configured on the repo webhook to enable verification.
BITBUCKET_WEBHOOK_UUID=

# --- LLM provider API keys ---
# Used by the built-in provider seeds in config/providers.yaml when
# auth_method references env://ANTHROPIC_API_KEY etc.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- Model pricing overrides ---
# Comma-separated list of `<model>=<input_per_1M>/<output_per_1M>` USD entries
# that override or extend the built-in cost table in internal/agent/runtime.go.
# Example: PHALANX_MODEL_PRICING=my-private-model=2.5/10,custom-mini=0.1/0.4
PHALANX_MODEL_PRICING=

# --- Optional: Vault-backed secrets ---
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=
# VAULT_KV_MOUNT=secret
